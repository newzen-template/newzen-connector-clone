{
  "name": "newzen-connector",
  "version": "1.0.82-beta.0",
  "description": "",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.mjs"
    },
    "./dist/style.css": "./dist/style.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist/",
    "src/bin/"
  ],
  "scripts": {
    "prepublishOnly": "pnpm run build",
    "build": "rimraf ./dist && pnpm tsup && copy .\\src\\style.css .\\dist",
    "lint": "eslint --ignore-path .eslintignore --ext .js,.ts .",
    "lint-fix": "eslint --fix",
    "server": "http-server -c-1 -p 8081 -o index.html",
    "dev": "concurrently \"tsup --watch\" \"pnpm run server\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bin": {
    "newzen": "./src/bin/index.js"
  },
  "devDependencies": {
    "@types/node": "^20.3.1",
    "@typescript-eslint/eslint-plugin": "^5.60.0",
    "@typescript-eslint/parser": "^5.60.0",
    "concurrently": "^8.2.0",
    "eslint": "^8.43.0",
    "http-server": "^14.1.1",
    "rimraf": "^3.0.2",
    "tsup": "^7.0.0",
    "typescript": "^5.1.3"
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  }
}
